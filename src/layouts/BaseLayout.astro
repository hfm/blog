---
import '../styles/site.css';
import { SITE_AUTHOR, SITE_DESCRIPTION, SITE_TITLE, SITE_URL, TWITTER_HANDLE } from '../consts';
import { buildYearMap, getPublishedPosts } from '../lib/posts';

interface Props {
  title?: string;
  description?: string;
  image?: string;
  date?: Date;
}

const { title, description = SITE_DESCRIPTION, image, date } = Astro.props;
const pageTitle = title ? `${title} | ${SITE_TITLE}` : SITE_TITLE;
const pageUrl = new URL(Astro.url.pathname, SITE_URL).toString();
const imageUrl = image ? new URL(image, SITE_URL).toString() : undefined;
const archiveYears = [...buildYearMap(await getPublishedPosts()).keys()];
---
<!DOCTYPE html>
<html prefix="og: http://ogp.me/ns# fb: http://ogp.me/ns/fb#" itemscope itemtype="http://schema.org/Blog" lang="ja">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <link href="/feed.xml" rel="alternate" type="application/rss+xml" title={SITE_TITLE} />
    <link href="/feed.xml" rel="feed" type="application/rss+xml" title={SITE_TITLE} />

    <meta name="description" content={description} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:site" content={TWITTER_HANDLE} />
    <meta name="twitter:creator" content={TWITTER_HANDLE} />

    <meta property="og:title" content={title ?? SITE_TITLE} />
    <meta property="og:site_name" content={SITE_TITLE} />
    <meta property="og:url" content={pageUrl} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="article" />
    <meta property="article:author" content={SITE_AUTHOR} />
    {imageUrl && <meta property="og:image" content={imageUrl} />}
    {date && <meta property="article:published_time" content={date.toISOString()} />}

    <script is:inline>
      (function(i,s,o,g,r,a,m){i['GoogleAnalyticsObject']=r;i[r]=i[r]||function(){
      (i[r].q=i[r].q||[]).push(arguments)},i[r].l=1*new Date();a=s.createElement(o),
      m=s.getElementsByTagName(o)[0];a.async=1;a.src=g;m.parentNode.insertBefore(a,m)
      })(window,document,'script','//www.google-analytics.com/analytics.js','ga');

      ga('create', 'UA-18235043-7', 'hifumi.info');
      ga('require', 'displayfeatures');
      ga('send', 'pageview');
    </script>
  </head>
  <body>
    <header id="header" itemprop="publisher" itemscope itemtype="http://schema.org/Organization">
      <h1 id="sitename" itemprop="name">
        <a href="/" itemprop="url">{SITE_TITLE}</a>
      </h1>
    </header>
    <div class="wrapper">
      <slot />
    </div>
    <footer id="footer">
      <div class="profile clearfix">
        <div class="wrapper">
          <img src="https://s.gravatar.com/avatar/47e8318347fb8cd6a2c39bc6cf6e333e?s=80" class="profile_image" alt="profile image" />
          <div class="footer-body">
            <div class="footer-profile">
              <div>
                <span itemprop="author" itemscope itemtype="http://schema.org/Person">
                  <span itemprop="name">{SITE_AUTHOR}</span>
                </span>
                <br />
                Site Reliability Engineer
              </div>
              <br />
              <div class="profile_contact">
                <ul>
                  <li><a href="/feed.xml"><img src="/images/rss@2x.png" alt="RSS Feed" /></a></li>
                  <li><a href="https://twitter.com/hfm" target="_blank"><img src="/images/twitter@2x.png" alt="Twitter @hfm" /></a></li>
                  <li><a href="https://github.com/hfm" target="_blank"><img src="/images/github@2x.png" alt="GitHub" /></a></li>
                </ul>
              </div>
            </div>
            <div class="footer-archives">
              <h2>Archives</h2>
              <ul>
                {archiveYears.map((year) => (
                  <li><a href={`/year/${year}/`}>{year}</a></li>
                ))}
              </ul>
            </div>
          </div>
        </div>
      </div>
    </footer>
  </body>
</html>
